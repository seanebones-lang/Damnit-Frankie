# xAI — required for chat + Eve TTS
XAI_API_KEY=

# Model id — must match a model enabled for your team (Console → Models).
# Docs: https://docs.x.ai/developers/models
# Default matches repo; examples: grok-4-1-fast-non-reasoning, grok-4-1-fast-reasoning, grok-4.20-0309-non-reasoning
XAI_MODEL=grok-4-1-fast-non-reasoning

# Optional: POST JSON payloads for booking + travel waitlist (Zapier, Make, Slack, CRM)
BOOKING_WEBHOOK_URL=

# Canonical site URL for metadata / OG
NEXT_PUBLIC_SITE_URL=https://damnitfrankie.com
